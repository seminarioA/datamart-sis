# ============================================================
# DATAMART SIS — Variables de entorno
# Copiar este archivo como .env y completar los valores
# ============================================================

# Connection string de Supabase (PostgreSQL)
# Formato: postgresql://postgres.[project-ref]:[password]@[host]:5432/postgres
DATABASE_URL=postgresql://postgres.XXXX:PASSWORD@aws-0-us-east-1.pooler.supabase.com:5432/postgres

# Schema del DataMart
DB_SCHEMA=datamart_sis

# Directorio de datos descargados
DATA_RAW_DIR=./data/raw
DATA_PROCESSED_DIR=./data/processed

# Tamaño del batch para carga a BD (filas por INSERT)
BATCH_SIZE=5000

# Nivel de log: DEBUG, INFO, WARNING, ERROR
LOG_LEVEL=INFO
