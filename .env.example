# ── DataMart SIS — Variables de entorno ──────────────────────────────────────

# Contraseña de PostgreSQL (cambiar en producción)
POSTGRES_PASSWORD=datamart2024

# URL completa de conexión (auto-generada en docker-compose)
# En desarrollo local apunta al contenedor:
# REQUERIDA — la app falla al iniciar si no está seteada (no hay default en código).
DATABASE_URL=postgresql://datamart:datamart2024@localhost:5433/datamart_sis

# ── Configuración de cache / MVs / pool (web/app.py) — todas opcionales ──────
LOG_LEVEL=INFO
CACHE_MEM_TTL_SECONDS=900
CACHE_DISK_TTL_SECONDS=3600
MV_REFRESH_INTERVAL_SECONDS=600
DB_CONNECT_TIMEOUT_SECONDS=10
DB_POOL_MIN=1
DB_POOL_MAX=10
DB_WORK_MEM=256MB
TOP_SERVICIOS_LIMIT=15
